import boto3
from botocore.exceptions import ClientError

def create_guardrail_version(guardrail_id, description=None):
    """
    Creates a numbered version (1, 2, 3, etc.) from the DRAFT version.
    
    Args:
        guardrail_id (str): The ID of the guardrail
        description (str): Optional description for the version
    
    Returns:
        dict: Response containing the new version details
    """
    try:
        bedrock_client = boto3.client('bedrock')
        
        params = {
            'guardrailIdentifier': guardrail_id
        }
        
        if description:
            params['description'] = description
        
        response = bedrock_client.create_guardrail_version(**params)
        
        print(f"Created version {response['version']} for guardrail {response['guardrailId']}")
        return response
        
    except ClientError as e:
        print(f"Error creating guardrail version: {e}")
        raise

# Example usage
if __name__ == "__main__":
    # Replace with your actual guardrail ID
    guardrail_id = "your-guardrail-id-here"
    
    # Create version 1 from DRAFT
    version_response = create_guardrail_version(
        guardrail_id=guardrail_id,
        description="First production version"
    )
    
    print(f"New version created: {version_response['version']}")
    print(f"Guardrail ID: {version_response['guardrailId']}")

